# Agent-private workspace (plans, markers, settings)
/.claude/

# Build output
/bin/
/dist/
/build/

# Embedded phar is built at release time, not committed
/internal/embed/phar/*.phar

# Staged framework tree (output of scripts/stage). Regenerated per-build by
# CI; never committed. The .gitkeep marker is tracked so go:embed has an
# entrypoint in clean checkouts.
/internal/project/framework/*
!/internal/project/framework/.gitkeep

# Go
*.exe
*.test
*.out
vendor/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Local env
.env
.env.local
